#!/usr/bin/env -S uv run --quiet --script
# /// script
# requires-python = ">=3.12"
# dependencies = [
#     "typer",
#     "rich",
#     "pydantic",
#     "pydantic-settings",
# ]
# ///

from __future__ import annotations

import json
import shlex
import shutil
import sqlite3
import subprocess
from dataclasses import dataclass
from pathlib import Path
from typing import Any, Optional

from collections.abc import Callable, Sequence

import typer
from pydantic import Field
from pydantic_settings import BaseSettings, SettingsConfigDict
from rich import box
from rich.console import Console
from rich.table import Table

app = typer.Typer(help="GitHub ↔ Forgejo repo migration helper")
console = Console()


# ---------------------------------------------------------------------------
# Settings
# ---------------------------------------------------------------------------


class Settings(BaseSettings):
    """Configuration for repostat.

    Values are loaded from environment variables with prefix ``GIT_MIGRATOR_``.
    """

    model_config = SettingsConfigDict(env_prefix="GIT_MIGRATOR_", extra="ignore")

    db: Path = Field(default_factory=lambda: Path.home() / ".local" / "state" / "git-migrator" / "repos.db")
    root: Path = Field(default_factory=lambda: Path.home() / "git")
    gh: str = "gh"
    tea: str = "tea"
    tea_login: str = "git.wayl.one"
    # New: used to build Forgejo URLs for README + Git remotes
    forgejo_base_url: str = "https://git.wayl.one"
    forgejo_default_owner: str = "waylon"

settings = Settings()


# ---------------------------------------------------------------------------
# DB setup
# ---------------------------------------------------------------------------


def get_conn() -> sqlite3.Connection:
    path = settings.db
    path.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(path)
    conn.row_factory = sqlite3.Row
    init_db(conn)
    return conn


def init_db(conn: sqlite3.Connection) -> None:
    cur = conn.cursor()
    cur.executescript(
        """
        CREATE TABLE IF NOT EXISTS github_repos (
            full_name     TEXT PRIMARY KEY,
            name          TEXT NOT NULL,
            owner         TEXT NOT NULL,
            ssh_url       TEXT,
            https_url     TEXT,
            archived      INTEGER,
            private       INTEGER,
            fork          INTEGER,
            description   TEXT,
            updated_at    TEXT,
            pushed_at     TEXT
        );

        CREATE TABLE IF NOT EXISTS forgejo_repos (
            full_name     TEXT PRIMARY KEY,
            name          TEXT NOT NULL,
            owner         TEXT NOT NULL,
            ssh_url       TEXT,
            https_url     TEXT,
            private       INTEGER,
            mirror        INTEGER,
            description   TEXT,
            updated_at    TEXT
        );

        CREATE TABLE IF NOT EXISTS local_repos (
            path           TEXT PRIMARY KEY,
            name           TEXT NOT NULL,
            has_git        INTEGER NOT NULL,
            has_readme     INTEGER NOT NULL,
            primary_remote TEXT
        );

        CREATE TABLE IF NOT EXISTS migration_plan (
            id                INTEGER PRIMARY KEY AUTOINCREMENT,
            github_full_name  TEXT,
            forgejo_full_name TEXT,
            local_path        TEXT,
            plan              TEXT NOT NULL,
            created_at        TEXT DEFAULT (datetime('now'))
        );

        CREATE TABLE IF NOT EXISTS apply_history (
            id                 INTEGER PRIMARY KEY AUTOINCREMENT,
            migration_plan_id  INTEGER NOT NULL,
            applied_at         TEXT DEFAULT (datetime('now')),
            notes              TEXT,
            FOREIGN KEY (migration_plan_id) REFERENCES migration_plan(id)
        );
        """
    )
    conn.commit()


# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------


def run_json(cmd: Sequence[str]) -> list[dict[str, Any]]:
    """Run a command and parse JSON output as a list of objects."""
    try:
        result = subprocess.run(
            list(cmd),
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=True,
            text=True,
        )
    except FileNotFoundError as exc:
        console.print(f"[red]Command not found:[/red] {' '.join(cmd)}")
        raise typer.Exit(1) from exc
    except subprocess.CalledProcessError as exc:
        console.print(f"[red]Command failed:[/red] {' '.join(cmd)}")
        console.print(exc.stderr.strip())
        raise typer.Exit(1) from exc

    try:
        data = json.loads(result.stdout)
    except json.JSONDecodeError as exc:
        console.print("[red]Failed to parse JSON output from command:[/red]")
        console.print(" ", " ".join(cmd))
        console.print(result.stdout)
        console.print(str(exc))
        raise typer.Exit(1) from exc

    if not isinstance(data, list):
        console.print("[red]Expected JSON array from command.[/red]")
        raise typer.Exit(1)

    return data


def git_has_git_dir(path: Path) -> bool:
    return (path / ".git").is_dir()


def git_primary_remote(path: Path) -> Optional[str]:
    if not git_has_git_dir(path):
        return None
    try:
        result = subprocess.run(
            ["git", "-C", str(path), "remote", "-v"],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            check=True,
        )
    except subprocess.CalledProcessError:
        return None

    remotes: dict[str, str] = {}
    for line in result.stdout.splitlines():
        parts = line.split()
        if len(parts) >= 3:
            name, url, kind = parts[0], parts[1], parts[2]
            if kind.startswith("(fetch") and name not in remotes:
                remotes[name] = url
    if "origin" in remotes:
        return remotes["origin"]
    return next(iter(remotes.values()), None)


def has_readme(path: Path) -> bool:
    if not path.is_dir():
        return False
    for name in path.iterdir():
        if name.is_file() and name.name.lower().startswith("readme"):
            return True
    return False


# ---------------------------------------------------------------------------
# Fuzzy selection helpers (fzf + fallback)
# ---------------------------------------------------------------------------


def fuzzy_score(query: str, text: str) -> int:
    """Very simple fuzzy scorer."""
    q = query.lower().strip()
    t = text.lower()
    if not q:
        return 0
    score = 0
    pos = 0
    for ch in q:
        idx = t.find(ch, pos)
        if idx == -1:
            return -1
        score += 1
        if idx == pos:
            score += 1
        pos = idx + 1
    return score


def _choose_fuzzy_fallback(
    items: Sequence[object],
    label_fn: Callable[[object], str],
) -> Optional[object]:
    """Old-school text picker used when fzf is unavailable."""

    if not items:
        console.print("[yellow]No items to choose from.[/yellow]")
        return None

    while True:
        console.print(
            "\nType a search string (or just press Enter to quit):",
            style="bold",
        )
        query = input("> ").strip()
        if not query:
            return None

        scored: list[tuple[int, object]] = []
        for it in items:
            label = label_fn(it)
            s = fuzzy_score(query, label)
            if s >= 0:
                scored.append((s, it))

        if not scored:
            console.print("[red]No matches. Try again.[/red]")
            continue

        scored.sort(key=lambda x: x[0], reverse=True)
        top = scored[:10]

        table = Table(show_header=True, header_style="bold magenta", box=box.SIMPLE)
        table.add_column("#", justify="right")
        table.add_column("Score", justify="right")
        table.add_column("Item")

        for idx, (s, it) in enumerate(top, start=1):
            table.add_row(str(idx), str(s), label_fn(it))

        console.print(table)
        console.print("Pick a number, [b]n[/b] for new search, or [b]q[/b] to quit.")

        choice = input("Selection: ").strip().lower()
        if choice in {"q", "quit"}:
            return None
        if choice in {"n", ""}:
            continue
        try:
            idx = int(choice)
        except ValueError:
            console.print("[red]Invalid choice.[/red]")
            continue
        if 1 <= idx <= len(top):
            return top[idx - 1][1]
        console.print("[red]Out of range.[/red]")


def choose_interactive(
    items: Sequence[object],
    label_fn: Callable[[object], str],
) -> Optional[object]:
    """Interactive picker that prefers fzf if available."""
    if not items:
        console.print("[yellow]No items to choose from.[/yellow]")
        return None

    if shutil.which("fzf") is None:
        console.print(
            "[yellow]fzf not found in PATH, using simple picker instead.[/yellow]"
        )
        return _choose_fuzzy_fallback(items, label_fn)

    lines: list[str] = []
    for idx, it in enumerate(items):
        label = label_fn(it)
        lines.append(f"{idx}\t{label}")

    try:
        proc = subprocess.run(
            ["fzf", "--ansi"],
            input="\n".join(lines),
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            check=False,
        )
    except FileNotFoundError:
        console.print(
            "[yellow]fzf command not found, falling back to simple picker.[/yellow]"
        )
        return _choose_fuzzy_fallback(items, label_fn)

    if proc.returncode != 0 or not proc.stdout:
        # User cancelled / no selection
        return None

    selected_line = proc.stdout.strip().splitlines()[-1]
    idx_str = selected_line.split("\t", 1)[0]
    try:
        idx = int(idx_str)
    except ValueError:
        console.print(
            "[red]Failed to parse fzf selection; falling back to simple picker.[/red]"
        )
        return _choose_fuzzy_fallback(items, label_fn)

    if 0 <= idx < len(items):
        return items[idx]
    console.print("[red]fzf returned out-of-range index; ignoring selection.[/red]")
    return None


# ---------------------------------------------------------------------------
# Refresh commands
# ---------------------------------------------------------------------------


@app.command()
def refresh(
    github: bool = typer.Option(True, help="Refresh GitHub repos via gh"),
    forgejo: bool = typer.Option(True, help="Refresh Forgejo repos via tea"),
    local: bool = typer.Option(True, help="Refresh local repos under ~/git"),
) -> None:
    """Refresh cached data from GitHub, Forgejo, and local filesystem."""

    conn = get_conn()
    cur = conn.cursor()

    if github:
        console.rule("GitHub repos")
        cmd = [
            settings.gh,
            "repo",
            "list",
            "--limit",
            "1000",
            "--json",
            ",".join(
                [
                    "name",
                    "nameWithOwner",
                    "owner",
                    "sshUrl",
                    "url",  # HTTPS clone URL / HTML URL
                    "isArchived",
                    "isPrivate",
                    "isFork",
                    "description",
                    "updatedAt",
                    "pushedAt",
                ]
            ),
        ]
        data = run_json(cmd)
        cur.execute("DELETE FROM github_repos")
        for item in data:
            owner = item.get("owner")
            owner_login = owner.get("login") if isinstance(owner, dict) else owner

            full_name = item.get("nameWithOwner") or (
                f"{owner_login}/{item['name']}" if owner_login else item["name"]
            )

            cur.execute(
                """
                INSERT OR REPLACE INTO github_repos (
                    full_name, name, owner, ssh_url, https_url,
                    archived, private, fork, description,
                    updated_at, pushed_at
                ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                """,
                (
                    full_name,
                    item["name"],
                    owner_login or "",
                    item.get("sshUrl"),
                    item.get("url"),
                    int(bool(item.get("isArchived"))),
                    int(bool(item.get("isPrivate"))),
                    int(bool(item.get("isFork"))),
                    item.get("description"),
                    item.get("updatedAt"),
                    item.get("pushedAt"),
                ),
            )

        conn.commit()
        console.print(f"Stored [green]{len(data)}[/green] GitHub repos.")

    if forgejo:
        console.rule("Forgejo repos (tea)")
        all_items: list[dict] = []
        page = 1
        per_page = 50  # Forgejo max per page

        try:
            while True:
                page_items = run_json(
                    [
                        settings.tea,
                        "repos",
                        "ls",
                        "--login",
                        settings.tea_login,
                        "--output",
                        "json",
                        "--limit",
                        str(per_page),
                        "--page",
                        str(page),
                    ]
                )

                # tea returns [] when there are no more repos
                if not page_items:
                    break

                all_items.extend(page_items)

                # If we got fewer than per_page, this was the last page
                if len(page_items) < per_page:
                    break

                page += 1

        except typer.Exit:
            console.print(
                "[yellow]Skipping Forgejo refresh: failed to run `tea repos ls --output json`.\n"
                "You may need to upgrade tea, fix your login, or adjust the command in this script.[/yellow]"
            )
            all_items = []

        data = all_items

        if data:
            cur.execute("DELETE FROM forgejo_repos")
            for item in data:
                name = item.get("name") or item.get("repoName")
                owner = item.get("owner")
                owner_name = (
                    owner.get("name")
                    if isinstance(owner, dict)
                    else item.get("owner_name")
                )
                full_name = item.get("full_name") or (
                    f"{owner_name}/{name}" if owner_name and name else name
                )
                ssh_url = item.get("ssh_url") or item.get("sshUrl")
                https_url = (
                    item.get("clone_url")
                    or item.get("html_url")
                    or item.get("cloneUrl")
                )
                private = int(bool(item.get("private")))
                mirror = int(bool(item.get("mirror")))
                description = item.get("description")
                updated_at = item.get("updated_at") or item.get("updatedAt")

                if not name:
                    continue
                cur.execute(
                    """
                    INSERT OR REPLACE INTO forgejo_repos (
                        full_name, name, owner, ssh_url, https_url,
                        private, mirror, description, updated_at
                    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
                    """,
                    (
                        full_name or name,
                        name,
                        owner_name or "",
                        ssh_url,
                        https_url,
                        private,
                        mirror,
                        description,
                        updated_at,
                    ),
                )
            conn.commit()
            console.print(f"Stored [green]{len(data)}[/green] Forgejo repos.")
    if local:
        console.rule("Local repos")
        root = settings.root
        if not root.exists():
            console.print(f"[yellow]Local root does not exist:[/yellow] {root}")
        else:
            cur.execute("DELETE FROM local_repos")
            count = 0
            for entry in sorted(root.iterdir()):
                if not entry.is_dir() or entry.name.startswith("."):
                    continue
                has_git = int(git_has_git_dir(entry))
                readme = int(has_readme(entry))
                remote = git_primary_remote(entry) if has_git else None
                cur.execute(
                    """
                    INSERT OR REPLACE INTO local_repos (
                        path, name, has_git, has_readme, primary_remote
                    ) VALUES (?, ?, ?, ?, ?)
                    """,
                    (str(entry), entry.name, has_git, readme, remote),
                )
                count += 1
            conn.commit()
            console.print(
                f"Indexed [green]{count}[/green] local directories under {root}."
            )

    console.print("[green]Refresh complete.[/green]")


# ---------------------------------------------------------------------------
# Show missing bits
# ---------------------------------------------------------------------------


@app.command("show-missing")
def show_missing() -> None:
    """Show local repos missing .git, a remote, or a README."""

    conn = get_conn()
    cur = conn.cursor()

    cur.execute("SELECT * FROM local_repos ORDER BY name")
    rows = cur.fetchall()
    if not rows:
        console.print(
            "[yellow]No local repos recorded. Run `repostat refresh --local` first.[/yellow]"
        )
        raise typer.Exit(0)

    missing_git = [r for r in rows if not r["has_git"]]
    missing_remote = [r for r in rows if r["has_git"] and not r["primary_remote"]]
    missing_readme = [r for r in rows if not r["has_readme"]]

    def render(title: str, subset: list[sqlite3.Row]) -> None:
        console.rule(title)
        if not subset:
            console.print("[green]None.[/green]")
            return
        table = Table(show_header=True, header_style="bold cyan", box=box.SIMPLE)
        table.add_column("Name")
        table.add_column("Path")
        table.add_column("Has .git")
        table.add_column("Has README")
        table.add_column("Remote")
        for r in subset:
            table.add_row(
                r["name"],
                r["path"],
                "yes" if r["has_git"] else "no",
                "yes" if r["has_readme"] else "no",
                r["primary_remote"] or "",
            )
        console.print(table)

    render("Missing .git", missing_git)
    render("Missing remote", missing_remote)
    render("Missing README", missing_readme)


# ---------------------------------------------------------------------------
# Show repos only in GitHub
# ---------------------------------------------------------------------------

from dataclasses import dataclass, field
from pathlib import Path
from typing import Any, Optional
# (you already import dataclass/Path/Optional; just add `field` if needed)

CHECK = "[green]✓[/green]"
CROSS = "[red]✗[/red]"
DOT = "[dim]·[/dim]"


@dataclass
class ProjectStatus:
    name: str
    github: bool = False
    forgejo: bool = False
    local_path: Path | None = None
    local_clean: bool | None = None
    local_branch: str | None = None
    worktrees: list[str] = field(default_factory=list)


def git_output(args: list[str], cwd: Path) -> str:
    """Run a git command in `cwd` and return stdout ('' on error)."""
    try:
        proc = subprocess.run(
            ["git", "-C", str(cwd), *args],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            check=True,
        )
    except subprocess.CalledProcessError:
        return ""
    return proc.stdout.strip()


def git_is_clean(path: Path) -> bool | None:
    """Return True/False if repo is clean/dirty, or None if not a git repo."""
    if not git_has_git_dir(path):
        return None
    out = git_output(["status", "--porcelain"], path)
    return out == ""


def git_current_branch(path: Path) -> str | None:
    if not git_has_git_dir(path):
        return None
    out = git_output(["rev-parse", "--abbrev-ref", "HEAD"], path)
    return out or None


def git_worktrees(path: Path) -> list[str]:
    """Return worktrees as `branch@/path/to/worktree` strings."""
    if not git_has_git_dir(path):
        return []

    out = git_output(["worktree", "list", "--porcelain"], path)
    if not out:
        return []

    worktrees: list[str] = []
    current_path: str | None = None
    current_branch: str | None = None

    for line in out.splitlines():
        if line.startswith("worktree "):
            current_path = line.split(" ", 1)[1]
        elif line.startswith("branch "):
            current_branch = line.split(" ", 1)[1]
        elif line == "" and current_path:
            # end of block
            label = f"{current_branch or '?'}@{current_path}"
            worktrees.append(label)
            current_path = None
            current_branch = None

    if current_path:
        label = f"{current_branch or '?'}@{current_path}"
        worktrees.append(label)

    return worktrees


def _get_project(
    projects: dict[str, ProjectStatus],
    name: str,
) -> ProjectStatus:
    if name not in projects:
        projects[name] = ProjectStatus(name=name)
    return projects[name]

def load_github_projects(conn: sqlite3.Connection) -> dict[str, ProjectStatus]:
    """Load GitHub repos into a {name -> ProjectStatus} mapping."""
    projects: dict[str, ProjectStatus] = {}
    cur = conn.cursor()
    cur.execute("SELECT name FROM github_repos")
    for (name,) in cur.fetchall():
        _get_project(projects, name).github = True
    return projects


def load_forgejo_projects(
    conn: sqlite3.Connection,
    projects: dict[str, ProjectStatus],
) -> None:
    """Mark repos that exist in Forgejo."""
    cur = conn.cursor()
    cur.execute("SELECT name FROM forgejo_repos")
    for (name,) in cur.fetchall():
        _get_project(projects, name).forgejo = True


def load_local_projects(
    conn: sqlite3.Connection,
    projects: dict[str, ProjectStatus],
) -> None:
    """Attach local path / git status / worktrees."""
    cur = conn.cursor()
    cur.execute("SELECT path, name, has_git FROM local_repos")
    for row in cur.fetchall():
        path = Path(row["path"])
        name = row["name"]
        has_git_flag = bool(row["has_git"])

        proj = _get_project(projects, name)
        proj.local_path = path if path.exists() else None

        if has_git_flag and path.exists():
            proj.local_clean = git_is_clean(path)
            proj.local_branch = git_current_branch(path)
            proj.worktrees = git_worktrees(path)
        else:
            proj.local_clean = None
            proj.local_branch = None
            proj.worktrees = []


@app.command("show")
def show() -> None:
    """Show combined status for GitHub, Forgejo, and local repos."""

    conn = get_conn()
    try:
        projects = load_github_projects(conn)
        load_forgejo_projects(conn, projects)
        load_local_projects(conn, projects)
    finally:
        conn.close()

    if not projects:
        console.print(
            "[yellow]No repos in DB yet. Run `repostat refresh` first.[/yellow]"
        )
        raise typer.Exit(0)

    console.rule("Repository overview")

    table = Table(show_header=True, header_style="bold cyan", box=box.SIMPLE)
    table.add_column("Name")
    table.add_column("GitHub", justify="center")
    table.add_column("Forgejo", justify="center")
    table.add_column("Local", justify="center")
    table.add_column("Clean", justify="center")
    table.add_column("Branch")
    table.add_column("Worktrees")

    for name in sorted(projects.keys(), key=str.lower):
        p = projects[name]

        github_cell = CHECK if p.github else DOT
        forgejo_cell = CHECK if p.forgejo else DOT
        local_cell = CHECK if p.local_path else DOT

        if p.local_clean is None:
            clean_cell = DOT
        else:
            clean_cell = CHECK if p.local_clean else CROSS

        worktrees_str = "\n".join(p.worktrees) if p.worktrees else ""

        table.add_row(
            name,
            github_cell,
            forgejo_cell,
            local_cell,
            clean_cell,
            p.local_branch or "",
            worktrees_str,
        )

    console.print(table)



@app.command("show-only-github")
def show_only_github() -> None:
    """Show repos that exist on GitHub but not in Forgejo or ``~/git``."""

    conn = get_conn()
    cur = conn.cursor()

    cur.execute("SELECT * FROM github_repos")
    gh_rows = cur.fetchall()
    if not gh_rows:
        console.print(
            "[yellow]No GitHub repos in DB. Run `repostat refresh --github` first.[/yellow]"
        )
        raise typer.Exit(0)

    cur.execute("SELECT DISTINCT name FROM forgejo_repos")
    forgejo_names = {r[0] for r in cur.fetchall()}

    cur.execute("SELECT DISTINCT name FROM local_repos")
    local_names = {r[0] for r in cur.fetchall()}

    only = [
        r
        for r in gh_rows
        if r["name"] not in forgejo_names and r["name"] not in local_names
    ]

    console.rule("GitHub-only repos (by name)")
    if not only:
        console.print(
            "[green]Every GitHub repo has a Forgejo/local counterpart by name.[/green]"
        )
        return

    table = Table(show_header=True, header_style="bold magenta", box=box.SIMPLE)
    table.add_column("Full name")
    table.add_column("Private")
    table.add_column("Archived")
    table.add_column("Fork")
    table.add_column("URL")

    for r in sorted(only, key=lambda x: x["full_name"]):
        table.add_row(
            r["full_name"],
            "yes" if r["private"] else "no",
            "yes" if r["archived"] else "no",
            "yes" if r["fork"] else "no",
            r["https_url"] or r["ssh_url"] or "",
        )

    console.print(table)


# ---------------------------------------------------------------------------
# newrepo
# ---------------------------------------------------------------------------


@app.command("newrepo")
def pick_newrepo() -> None:
    """Fuzzy-pick local dirs to run ``newrepo`` in."""

    conn = get_conn()
    cur = conn.cursor()
    cur.execute("SELECT * FROM local_repos ORDER BY name")
    rows = cur.fetchall()
    if not rows:
        console.print(
            "[yellow]No local repos in DB. Run `repostat refresh --local` first.[/yellow]"
        )
        raise typer.Exit(0)

    candidates = [
        r
        for r in rows
        if (not r["has_git"] or not r["primary_remote"] or not r["has_readme"])
    ]
    if not candidates:
        console.print(
            "[green]Every local repo has .git, remote, and README. Nothing to do.[/green]"
        )
        return

    console.print(
        "[cyan]Selecting among local directories missing .git, remote, or README.[/cyan]",
    )

    while True:
        picked = choose_interactive(
            candidates,
            label_fn=lambda r: f"{r['name']} :: {r['path']} [git={bool(r['has_git'])}, readme={bool(r['has_readme'])}]",
        )
        if picked is None:
            console.print("[green]Done.[/green]")
            break

        path = Path(picked["path"])  # type: ignore[index]
        console.rule(f"Running newrepo in {path}")
        if not path.is_dir():
            console.print(f"[red]Path no longer exists:[/red] {path}")
            continue

        cmd = f"cd {shlex.quote(str(path))} && newrepo"
        console.print(f"[blue]{cmd}[/blue]")
        try:
            subprocess.run(cmd, shell=True, check=True)
        except subprocess.CalledProcessError as exc:
            console.print(
                f"[red]newrepo failed with exit code {exc.returncode}[/red]"
            )
            continue

        # Re-scan this directory
        has_git_val = int(git_has_git_dir(path))
        readme_val = int(has_readme(path))
        remote_val = git_primary_remote(path) if has_git_val else None
        cur.execute(
            """
            INSERT OR REPLACE INTO local_repos (
                path, name, has_git, has_readme, primary_remote
            ) VALUES (?, ?, ?, ?, ?)
            """,
            (str(path), path.name, has_git_val, readme_val, remote_val),
        )
        conn.commit()
        console.print("[green]Updated DB for[/green]", str(path))

        cur.execute("SELECT * FROM local_repos ORDER BY name")
        rows = cur.fetchall()
        candidates = [
            r
            for r in rows
            if (not r["has_git"] or not r["primary_remote"] or not r["has_readme"])
        ]
        if not candidates:
            console.print(
                "[green]All local repos now have .git, remote, and README.[/green]"
            )
            break


# ---------------------------------------------------------------------------
# mirror / move
# ---------------------------------------------------------------------------


@dataclass
class GHRepo:
    full_name: str
    name: str
    private: bool
    archived: bool
    fork: bool
    url: str


def _load_github_repos(conn: sqlite3.Connection) -> list[GHRepo]:
    cur = conn.cursor()
    cur.execute("SELECT * FROM github_repos")
    rows = cur.fetchall()
    repos: list[GHRepo] = []

    if not rows:
        console.print(
            "[yellow]No GitHub repos in DB. Run `repostat refresh --github` first.[/yellow]"
        )
        return repos

    for r in rows:
        repos.append(
            GHRepo(
                full_name=r["full_name"],
                name=r["name"],
                private=bool(r["private"]),
                archived=bool(r["archived"]),
                fork=bool(r["fork"]),
                url=r["https_url"] or r["ssh_url"] or "",
            )
        )
    return repos


def _filter_github_only(
    conn: sqlite3.Connection,
    repos: list[GHRepo],
) -> list[GHRepo]:
    cur = conn.cursor()
    cur.execute("SELECT DISTINCT name FROM forgejo_repos")
    forgejo_names = {r[0] for r in cur.fetchall()}
    cur.execute("SELECT DISTINCT name FROM local_repos")
    local_names = {r[0] for r in cur.fetchall()}

    return [
        r for r in repos if r.name not in forgejo_names and r.name not in local_names
    ]

def _filter_github_not_in_forgejo(
    conn: sqlite3.Connection,
    repos: list[GHRepo],
) -> list[GHRepo]:
    """Return GitHub repos whose *name* is not present in Forgejo.

    This is used for pick-move so we don't offer repos that already exist
    in Forgejo.
    """
    cur = conn.cursor()
    cur.execute("SELECT DISTINCT name FROM forgejo_repos")
    forgejo_names = {r[0] for r in cur.fetchall()}

    return [r for r in repos if r.name not in forgejo_names]

def _filter_fork(repos: list[GHRepo]) -> list[GHRepo]:
    return [r for r in repos if not r.fork]

def _filter_archived(repos: list[GHRepo]) -> list[GHRepo]:
    return [r for r in repos if not r.archived]

def _filter_fork_only(repos: list[GHRepo]) -> list[GHRepo]:
    return [r for r in repos if r.fork]

def _filter_has_git(repos: list[GHRepo]) -> list[GHRepo]:
    return [r for r in repos if not r.has_git]

def _pick_gh_repos_for_plan(plan: str) -> None:
    conn = get_conn()
    repos = _load_github_repos(conn)
    if not repos:
        return

    # Still show the "GitHub-only" hint if you like
    gh_only = _filter_github_only(conn, repos)
    if gh_only:
        console.print(
            f"[cyan]There are {len(gh_only)} GitHub-only repos by name; those are good {plan} candidates.[/cyan]",
        )

    # NEW: actual candidate list excludes repos already in Forgejo
    candidate_repos = _filter_github_not_in_forgejo(conn, repos)
    candidate_repos = _filter_archived(candidate_repos)
    if plan == "rm":
        candidate_repos = _filter_fork_only(candidate_repos)
    else:
        candidate_repos = _filter_fork(candidate_repos)

    if not candidate_repos:
        console.print(
            "[green]All GitHub repos already exist in Forgejo by name; nothing to pick for move.[/green]"
        )
        return

    cur = conn.cursor()

    while True:
        picked = choose_interactive(
            candidate_repos,
            label_fn=lambda r: f"{r.full_name} :: private={r.private}, archived={r.archived}, fork={r.fork}",
        )
        if picked is None:
            console.print("[green]Done selecting.[/green]")
            break

        assert isinstance(picked, GHRepo)
        console.rule(f"Plan: {plan} :: {picked.full_name}")
        console.print(f"URL: {picked.url}")

        # TODO if desired to have different names in future
        forgejo_full = None
        # forgejo_full = input(
        #     "Forgejo full_name (owner/name) [press Enter to reuse repo name under your default user]: ",
        # ).strip()
        if not forgejo_full:
            forgejo_full = picked.name

        cur.execute(
            "SELECT path FROM local_repos WHERE primary_remote LIKE ?",
            (f"%{picked.name}.git",),
        )
        row = cur.fetchone()
        local_path = row[0] if row else None

        cur.execute(
            """
            INSERT INTO migration_plan (
                github_full_name, forgejo_full_name, local_path, plan
            ) VALUES (?, ?, ?, ?)
            """,
            (picked.full_name, forgejo_full, local_path, plan),
        )
        conn.commit()

        console.print(
            f"[green]Added migration_plan entry:[/green] {picked.full_name} -> {forgejo_full} ({plan})",
        )

        # Optionally: remove picked repo from candidates for this session
        candidate_repos = [r for r in candidate_repos if r.full_name != picked.full_name]


@app.command("mirror")
def pick_mirror() -> None:
    """Fuzzy-pick GitHub repos to *mirror* into Forgejo."""
    _pick_gh_repos_for_plan("mirror")


@app.command("move")
def pick_move() -> None:
    """Fuzzy-pick GitHub repos to *move* into Forgejo."""
    _pick_gh_repos_for_plan("move")


# ---------------------------------------------------------------------------
# plan / apply / history
# ---------------------------------------------------------------------------


def _fetch_plan_rows(conn: sqlite3.Connection) -> list[sqlite3.Row]:
    cur = conn.cursor()
    cur.execute("SELECT * FROM migration_plan ORDER BY created_at DESC, id DESC")
    return cur.fetchall()


def _render_plan_table(rows: Sequence[sqlite3.Row]) -> None:
    table = Table(show_header=True, header_style="bold green", box=box.SIMPLE)
    table.add_column("ID", justify="right")
    table.add_column("Plan")
    table.add_column("GitHub")
    table.add_column("Forgejo")
    table.add_column("Local path")
    table.add_column("Created")

    for r in rows:
        table.add_row(
            str(r["id"]),
            r["plan"],
            r["github_full_name"] or "",
            r["forgejo_full_name"] or "",
            r["local_path"] or "",
            r["created_at"] or "",
        )

    console.print(table)


@app.command("plan")
def plan_cmd() -> None:
    """Show the current migration *plan* (Terraform-style)."""

    conn = get_conn()
    rows = _fetch_plan_rows(conn)

    console.rule("Migration plan")
    if not rows:
        console.print("[yellow]No migration_plan entries yet.[/yellow]")
        console.print()
        console.print("[bold]Next steps:[/bold]")
        console.print(
            "- Use [cyan]repostat mirror[/cyan] or [cyan]repostat move[/cyan] to add items to the plan."
        )
        console.print(
            "- Run [cyan]repostat history[/cyan] to view previous apply runs."
        )
        console.print(
            "- Run [cyan]repostat refresh[/cyan] to sync GitHub / Forgejo / local state."
        )
        return

    _render_plan_table(rows)
    console.print()
    console.print("[bold]Next steps:[/bold]")
    console.print("- Run [cyan]repostat apply[/cyan] to record an apply of this plan.")
    console.print("- Run [cyan]repostat history[/cyan] to see previous apply runs.")


@app.command("show-plan")
def show_plan_alias() -> None:
    """Alias for :func:`plan_cmd` (kept for muscle memory)."""
    plan_cmd()

def execute_move_plan_row(conn: sqlite3.Connection, row: sqlite3.Row) -> None:
    """Execute a single 'move' plan entry.

    Steps:
    - Ensure we have a local checkout (clone if needed into settings.root).
    - Ensure local repo is clean.
    - Set GitHub repo public and archive it.
    - Create Forgejo repo with matching description/homepage.
    - Point local origin to Forgejo and push all branches + tags.
    - Record apply_history and remove from migration_plan.
    """
    plan_id = row["id"]
    github_full = row["github_full_name"]
    forgejo_full = row["forgejo_full_name"]
    local_path_str = row["local_path"]

    if not github_full:
        console.print(f"[red]Plan {plan_id}: missing github_full_name; skipping.[/red]")
        return
    if not forgejo_full:
        console.print(f"[red]Plan {plan_id}: missing forgejo_full_name; skipping.[/red]")
        return

    cur = conn.cursor()

    # --- resolve / create local_path -----------------------------------------
    local_path: Path | None = None
    if local_path_str:
        p = Path(local_path_str)
        if p.is_dir():
            local_path = p

    if local_path is None:
        console.print(
            f"[yellow]Plan {plan_id}: no usable local_path; cloning from GitHub into {settings.root}[/yellow]"
        )

        # Look up GitHub clone URL from github_repos table
        cur.execute(
            "SELECT https_url, ssh_url, name FROM github_repos WHERE full_name = ?",
            (github_full,),
        )
        repo_row = cur.fetchone()

        if repo_row is not None:
            repo_name = repo_row["name"]
            clone_url = (
                repo_row["https_url"]
                or repo_row["ssh_url"]
                or f"https://github.com/{github_full}.git"
            )
        else:
            owner, repo_name = github_full.split("/", 1)
            clone_url = f"https://github.com/{github_full}.git"

        local_path = settings.root / repo_name

        if local_path.exists() and not git_has_git_dir(local_path):
            console.print(
                f"[red]Plan {plan_id}: {local_path} exists but is not a git repo; please fix or remove it.[/red]"
            )
            raise typer.Exit(1)

        if not local_path.exists():
            local_path.parent.mkdir(parents=True, exist_ok=True)
            try:
                subprocess.run(
                    ["git", "clone", clone_url, str(local_path)],
                    check=True,
                    text=True,
                )
            except subprocess.CalledProcessError as exc:
                console.print(
                    f"[red]Plan {plan_id}: failed to clone {clone_url} into {local_path}[/red]"
                )
                console.print(exc.stderr)
                raise

        # Update local_repos + migration_plan.local_path
        has_git_val = int(git_has_git_dir(local_path))
        readme_val = int(has_readme(local_path))
        remote_val = git_primary_remote(local_path) if has_git_val else None

        cur.execute(
            """
            INSERT OR REPLACE INTO local_repos (
                path, name, has_git, has_readme, primary_remote
            ) VALUES (?, ?, ?, ?, ?)
            """,
            (str(local_path), local_path.name, has_git_val, readme_val, remote_val),
        )
        cur.execute(
            "UPDATE migration_plan SET local_path = ? WHERE id = ?",
            (str(local_path), plan_id),
        )
        conn.commit()

    assert local_path is not None

    # --- ensure repo is clean ------------------------------------------------
    try:
        status_proc = subprocess.run(
            ["git", "-C", str(local_path), "status", "--porcelain"],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            check=True,
        )
    except subprocess.CalledProcessError as exc:
        console.print(
            f"[red]Plan {plan_id}: failed to read git status for {local_path}[/red]"
        )
        console.print(exc.stderr)
        raise

    if status_proc.stdout.strip():
        console.print(
            f"[red]Plan {plan_id}: working tree is not clean for {local_path}; aborting move.[/red]"
        )
        console.print(
            "Commit or stash your changes before running [cyan]repostat apply[/cyan]."
        )
        raise typer.Exit(1)

    # --- parse Forgejo owner/name and URLs -----------------------------------
    if "/" in forgejo_full:
        forgejo_owner, forgejo_name = forgejo_full.split("/", 1)
    else:
        forgejo_owner = settings.forgejo_default_owner
        forgejo_name = forgejo_full

    forgejo_http_base = settings.forgejo_base_url.rstrip("/")
    forgejo_http_url = f"{forgejo_http_base}/{forgejo_owner}/{forgejo_name}"
    forgejo_git_url = f"{forgejo_http_url}.git"

    # --- fetch description/homepage from GitHub ------------------------------
    try:
        meta_proc = subprocess.run(
            [
                settings.gh,
                "repo",
                "view",
                github_full,
                "--json",
                "description,homepageUrl",
            ],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            check=True,
        )
        meta = json.loads(meta_proc.stdout)
        description = meta.get("description") or ""
        homepage = meta.get("homepageUrl") or ""
    except Exception as exc:  # noqa: BLE001
        console.print(
            f"[yellow]Plan {plan_id}: failed to fetch description/homepage from GitHub; proceeding without them.[/yellow]"
        )
        console.print(str(exc))
        description = ""
        homepage = ""

    # --- make repo public & archive on GitHub --------------------------------
    try:
        subprocess.run(
            [
                settings.gh,
                "repo",
                "edit",
                github_full,
                "--visibility",
                "public",
                "--accept-visibility-change-consequences",
            ],
            check=True,
            text=True,
        )
    except subprocess.CalledProcessError as exc:
        console.print(
            f"[yellow]Plan {plan_id}: failed to set visibility=public for {github_full}; continuing to archive.[/yellow]"
        )
        console.print(exc.stderr)

    try:
        subprocess.run(
            [settings.gh, "repo", "archive", github_full, "--yes"],
            check=True,
            text=True,
        )
    except subprocess.CalledProcessError as exc:
        console.print(
            f"[red]Plan {plan_id}: failed to archive GitHub repo {github_full}[/red]"
        )
        console.print(exc.stderr)
        raise

    # --- create Forgejo repo via tea -----------------------------------------
    tea_cmd = [
        settings.tea,
        "repo",
        "create",
        "--name",
        forgejo_name,
        "--login",
        settings.tea_login,
    ]
    if description:
        tea_cmd.extend(["--description", description])
    # if homepage:
    #     tea_cmd.extend(["--homepage", homepage])

    try:
        proc = subprocess.run(
            tea_cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            check=True,
        )
    except subprocess.CalledProcessError as exc:
        msg = (exc.stderr or "") + (exc.stdout or "")
        # If the repo already exists, treat that as OK (idempotent move)
        if "already exists" in msg or "exists" in msg or "409" in msg:
            console.print(
                f"[yellow]Plan {plan_id}: Forgejo repo {forgejo_owner}/{forgejo_name} already exists; continuing.[/yellow]"
            )
        else:
            console.print(
                f"[red]Plan {plan_id}: failed to create Forgejo repo {forgejo_owner}/{forgejo_name}[/red]"
            )
            console.print(msg)
            raise
    # --- point local origin at Forgejo ---------------------------------------
    try:
        subprocess.run(
            [
                "git",
                "-C",
                str(local_path),
                "remote",
                "set-url",
                "origin",
                forgejo_git_url,
            ],
            check=True,
            text=True,
        )
    except subprocess.CalledProcessError:
        try:
            subprocess.run(
                [
                    "git",
                    "-C",
                    str(local_path),
                    "remote",
                    "add",
                    "origin",
                    forgejo_git_url,
                ],
                check=True,
                text=True,
            )
        except subprocess.CalledProcessError as exc:
            console.print(
                f"[red]Plan {plan_id}: failed to configure origin remote for {local_path}[/red]"
            )
            console.print(exc.stderr)
            raise

    # --- push everything to Forgejo ------------------------------------------
    try:
        subprocess.run(
            ["git", "-C", str(local_path), "push", "--all", "origin"],
            check=True,
            text=True,
        )
        subprocess.run(
            ["git", "-C", str(local_path), "push", "--tags", "origin"],
            check=True,
            text=True,
        )
    except subprocess.CalledProcessError as exc:
        console.print(
            f"[red]Plan {plan_id}: failed to push branches/tags to Forgejo for {local_path}[/red]"
        )
        console.print(exc.stderr)
        raise

    # --- record history + clear from plan ------------------------------------
    cur.execute(
        "INSERT INTO apply_history (migration_plan_id, notes) VALUES (?, ?)",
        (plan_id, "moved to Forgejo via `repostat apply`"),
    )
    cur.execute("DELETE FROM migration_plan WHERE id = ?", (plan_id,))
    conn.commit()

    console.print(
        f"[green]Plan {plan_id}: successfully moved {github_full} to {forgejo_http_url}.[/green]"
    )

def execute_rm_plan_row(conn, r):
    """uses gh cli to delete a GitHub repo"""

    github_full = r["github_full_name"]
    console.print(f"Plan {r['id']}: removing GitHub repo {github_full}")

    try:
        subprocess.run(
            [settings.gh, "repo", "delete", github_full, '--yes'],
            check=True,
            text=True,
        )
    except subprocess.CalledProcessError as exc:
        console.print(f"Plan {r['id']}: failed to remove GitHub repo {github_full}")
        console.print(exc.stderr)
        console.print('you may need to set permissions to allo gh to delete_repo')
        console.print('gh auth refresh -h github.com -s delete_repo')
        raise

    console.print(f"Plan {r['id']}: successfully removed GitHub repo {github_full}")

    # --- record history + clear from plan ------------------------------------
    cur = conn.cursor()
    cur.execute(
        "INSERT INTO apply_history (migration_plan_id, notes) VALUES (?, ?)",
        (r["id"], "removed via `repostat apply`"),
    )
    cur.execute("DELETE FROM migration_plan WHERE id = ?", (r["id"],))
    conn.commit()


@app.command()
def apply() -> None:
    """Apply the current migration plan.

    For now:
    - plan == "move": perform the full move GitHub → Forgejo (see execute_move_plan_row).
    - any other plan: just record apply_history + delete from plan (as before).
    """

    conn = get_conn()
    cur = conn.cursor()

    cur.execute("SELECT * FROM migration_plan ORDER BY created_at DESC, id DESC")
    rows = cur.fetchall()

    console.rule("Apply migration plan")
    if not rows:
        console.print("[yellow]No migration_plan entries to apply.[/yellow]")
        console.print()
        console.print("[bold]Next steps:[/bold]")
        console.print("- Run [cyan]repostat plan[/cyan] (or [cyan]repostat show-plan[/cyan]) to see the current plan.")
        console.print("- Use [cyan]repostat mirror[/cyan] or [cyan]repostat move[/cyan] to build a plan.")
        return

    table = Table(show_header=True, header_style="bold green", box=box.SIMPLE)
    table.add_column("ID", justify="right")
    table.add_column("Plan")
    table.add_column("GitHub")
    table.add_column("Forgejo")
    table.add_column("Local path")

    for r in rows:
        table.add_row(
            str(r["id"]),
            r["plan"],
            r["github_full_name"] or "",
            r["forgejo_full_name"] or "",
            r["local_path"] or "",
        )

    console.print(table)

    # Execute each plan entry
    for r in rows:
        plan_type = r["plan"]
        if plan_type == "move":
            # This will also add to apply_history and delete the plan row
            execute_move_plan_row(conn, r)
        if plan_type =="rm":
            # This will also add to apply_history and delete the plan row
            execute_rm_plan_row(conn, r)
        else:
            # Default behavior: just record an apply and clear from plan
            cur.execute(
                "INSERT INTO apply_history (migration_plan_id, notes) VALUES (?, ?)",
                (r["id"], f"applied via `repostat apply` ({plan_type})"),
            )
            cur.execute("DELETE FROM migration_plan WHERE id = ?", (r["id"],))
            conn.commit()

    console.print("[green]Apply complete.[/green]")
    console.print()
    console.print("[bold]Next steps:[/bold]")
    console.print("- Run [cyan]repostat refresh[/cyan] to sync current repo state.")
    console.print("- Run [cyan]repostat history[/cyan] to view apply history.")


@app.command()
def history() -> None:
    """Show apply history for migration plans."""

    conn = get_conn()
    cur = conn.cursor()

    cur.execute(
        """
        SELECT
            h.id            AS history_id,
            h.applied_at    AS applied_at,
            h.notes         AS notes,
            p.id            AS plan_id,
            p.plan          AS plan,
            p.github_full_name,
            p.forgejo_full_name,
            p.local_path
        FROM apply_history h
        JOIN migration_plan p ON p.id = h.migration_plan_id
        ORDER BY h.applied_at DESC, h.id DESC
        """
    )
    rows = cur.fetchall()

    console.rule("Apply history")
    if not rows:
        console.print("[yellow]No applies recorded yet.[/yellow]")
        console.print()
        console.print("[bold]Next steps:[/bold]")
        console.print("- Run [cyan]repostat plan[/cyan] to see the current plan.")
        console.print("- Run [cyan]repostat apply[/cyan] to record an apply.")
        return

    table = Table(show_header=True, header_style="bold green", box=box.SIMPLE)
    table.add_column("History ID", justify="right")
    table.add_column("Applied at")
    table.add_column("Plan ID", justify="right")
    table.add_column("Plan")
    table.add_column("GitHub")
    table.add_column("Forgejo")
    table.add_column("Local path")
    table.add_column("Notes")

    for r in rows:
        table.add_row(
            str(r["history_id"]),
            r["applied_at"] or "",
            str(r["plan_id"]),
            r["plan"],
            r["github_full_name"] or "",
            r["forgejo_full_name"] or "",
            r["local_path"] or "",
            r["notes"] or "",
        )

    console.print(table)
    console.print()
    console.print("- Run [cyan]repostat plan[/cyan] to review the current plan.")
    console.print("- Run [cyan]repostat apply[/cyan] to record a new apply.")


# ---------------------------------------------------------------------------
# stats: quick overview / suggestions (and default command)
# ---------------------------------------------------------------------------


@app.command()
def stats() -> None:
    """Show a quick summary of what's in the DB and some suggestions."""

    conn = get_conn()
    cur = conn.cursor()

    def count(table: str) -> int:
        cur.execute(f"SELECT COUNT(*) FROM {table}")
        row = cur.fetchone()
        return int(row[0]) if row else 0

    gh_count = count("github_repos")
    fj_count = count("forgejo_repos")
    loc_count = count("local_repos")

    cur.execute("SELECT COUNT(*) FROM local_repos WHERE has_git = 0")
    missing_git = int(cur.fetchone()[0])
    cur.execute(
        "SELECT COUNT(*) FROM local_repos WHERE has_git = 1 AND (primary_remote IS NULL OR primary_remote = '')"
    )
    missing_remote = int(cur.fetchone()[0])
    cur.execute("SELECT COUNT(*) FROM local_repos WHERE has_readme = 0")
    missing_readme = int(cur.fetchone()[0])

    cur.execute("SELECT COUNT(*) FROM migration_plan")
    plan_count = int(cur.fetchone()[0])
    cur.execute("SELECT COUNT(*) FROM apply_history")
    history_count = int(cur.fetchone()[0])

    console.rule("Repo stats")
    table = Table(show_header=False, box=box.MINIMAL_DOUBLE_HEAD)
    table.add_row("GitHub repos", str(gh_count))
    table.add_row("Forgejo repos", str(fj_count))
    table.add_row("Local dirs", str(loc_count))
    table.add_row("Local missing .git", str(missing_git))
    table.add_row("Local missing remote", str(missing_remote))
    table.add_row("Local missing README", str(missing_readme))
    table.add_row("Migration plan entries", str(plan_count))
    table.add_row("Apply history entries", str(history_count))
    console.print(table)

    console.print()
    console.print("[bold]Suggested next steps:[/bold]")
    if loc_count == 0:
        console.print("- Run [cyan]repostat refresh --local[/cyan] to index ~/git.")
    if gh_count == 0:
        console.print("- Run [cyan]repostat refresh --github[/cyan] to pull your GitHub repos.")
    if fj_count == 0:
        console.print(
            "- Run [cyan]repostat refresh --forgejo[/cyan] to pull your Forgejo repos (via tea)."
        )
    if missing_git or missing_remote or missing_readme:
        console.print(
            "- Run [cyan]repostat show-missing[/cyan] and [cyan]repostat newrepo[/cyan] to clean up local repos."
        )
    if plan_count == 0:
        console.print(
            "- Build a plan with [cyan]repostat mirror[/cyan] or [cyan]repostat move[/cyan]."
        )
    else:
        console.print("- Review the current plan with [cyan]repostat plan[/cyan].")
        console.print("- Record an apply with [cyan]repostat apply[/cyan].")
    if history_count:
        console.print("- Inspect previous applies with [cyan]repostat history[/cyan].")
    if gh_count and fj_count:
        console.print(
            "- Run [cyan]repostat show-only-github[/cyan] to see repos that exist only on GitHub."
        )
        console.print(
            "- Use [cyan]repostat mirror[/cyan] or [cyan]repostat move[/cyan] to mark migration intents."
        )

@app.command("plan-rm")
def plan_rm(
    plan_id: int = typer.Argument(..., help="ID from `repostat plan`"),
) -> None:
    """Remove a single entry from the migration plan by ID."""

    conn = get_conn()
    cur = conn.cursor()

    cur.execute(
        "SELECT id, plan, github_full_name, forgejo_full_name, local_path "
        "FROM migration_plan WHERE id = ?",
        (plan_id,),
    )
    row = cur.fetchone()

    if row is None:
        console.print(f"[red]No migration_plan entry with id {plan_id}.[/red]")
        raise typer.Exit(1)

    console.rule("Remove from migration plan")
    table = Table(show_header=True, header_style="bold green", box=box.SIMPLE)
    table.add_column("ID", justify="right")
    table.add_column("Plan")
    table.add_column("GitHub")
    table.add_column("Forgejo")
    table.add_column("Local path")

    table.add_row(
        str(row["id"]),
        row["plan"],
        row["github_full_name"] or "",
        row["forgejo_full_name"] or "",
        row["local_path"] or "",
    )
    console.print(table)

    confirm = input(f"Remove plan entry {plan_id}? [y/N]: ").strip().lower()
    if confirm not in {"y", "yes"}:
        console.print("[yellow]Aborted; nothing removed.[/yellow]")
        raise typer.Exit(0)

    cur.execute("DELETE FROM migration_plan WHERE id = ?", (plan_id,))
    conn.commit()
    console.print(f"[green]Removed plan entry {plan_id} from migration_plan.[/green]")

@app.command("plan-rm-all")
def plan_rm_all() -> None:
    """Remove all entries from the migration plan."""
    conn = get_conn()
    cur = conn.cursor()
    cur.execute("DELETE FROM migration_plan")
    conn.commit()
    console.print("[green]Removed all migration_plan entries.[/green]")

@app.command("rm-fork")
def pick_rm_fork() -> None:
    """delete a repo from github"""

    _pick_gh_repos_for_plan("rm")

# ---------------------------------------------------------------------------
# Typer callback (default to stats)
# ---------------------------------------------------------------------------


@app.callback(invoke_without_command=True)
def main(ctx: typer.Context) -> None:
    """Entry point for repostat.

    If no subcommand is provided, this runs :func:`stats`.
    """
    if ctx.invoked_subcommand is None:
        stats()


# ---------------------------------------------------------------------------
# Entrypoint
# ---------------------------------------------------------------------------


if __name__ == "__main__":  # pragma: no cover
    app()

