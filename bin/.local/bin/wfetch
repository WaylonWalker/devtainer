#!/bin/bash
set -euo pipefail

PREVIEW_EFFECTS=false
EFFECT=""
FRAME_RATE=360
TIMEOUT=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --preview-effects)
            PREVIEW_EFFECTS=true
            shift
            ;;
        --effect)
            EFFECT="$2"
            shift 2
            ;;
        --frame-rate)
            FRAME_RATE="$2"
            shift 2
            ;;
        --timeout)
            TIMEOUT="$2"
            shift 2
            ;;
        *)
            shift
            ;;
    esac
done

get_os () {
    if [[ `command -v lsb_release` ]]; then
        os=`lsb_release -d | awk '{printf "%s %s", $2, $3}'`
    elif [[ -f /etc/os-release ]]; then
        . /etc/os-release
        os=$PRETTY_NAME
    fi
}

get_os
if [[ `command -v btrfs` ]]; then
        rootFree=`df -h / | awk '{print $4}' | tr -d '\n' | sed 's/Avail//'`
else
        rootFree=''
fi
if command -v free &> /dev/null; then
    memAvailable=`free -m | grep "Mem" | awk '{printf "%.1fG", $7/1024}'`
else
    memAvailable='-'
fi
cpuTemp=`echo "$(( $(cat /sys/class/thermal/thermal_zone0/temp) / 1000 ))"`
if [[ -f /proc/loadavg ]]; then
        loadAvg=`cat /proc/loadavg | awk '{printf "%s %s %s", $1, $2, $3}'`
else
        loadAvg=''
fi
if ! command -v /opt/cisco/anyconnect/bin/vpn &> /dev/null; then
        proxy=
elif [[ "$(/opt/cisco/anyconnect/bin/vpn status)"  == *"state: Disconnected"* ]]; then
        proxy=
else
        proxy=ﭝ
fi

cpuUsage=`top -bn1 | grep "Cpu(s)" | sed "s/.*, *\([0-9.]*\)%* id.*/\1/" | awk '{printf "%.0f", 100 - $1}'`
memUsage=`free | grep "Mem" | awk '{printf "%.1f", $3/$2*100}'`

get_content() {
    printf "  ╭───╮ ╭─────╮ ╭───╮
  │   │ │     │ │   │  $proxy $os
  │   ╰─╯     ╰─╯   │  $cpuTemp°C $cpuUsage $memUsage/$memAvailable $rootFree
  │ @_waylonwalker  │   `date`
  ╰─────────────────╯
"
}

run_effect() {
    local eff="$1"
    local content
    content=$(get_content)
    if [[ -n "$TIMEOUT" ]]; then
        timeout "$TIMEOUT" sh -c "printf '%s' \"\$1\" | tte --frame-rate $FRAME_RATE $eff" -- "$content"
    else
        printf '%s' "$content" | tte --frame-rate "$FRAME_RATE" "$eff"
    fi
}

if [[ "$PREVIEW_EFFECTS" == true ]]; then
    EFFECTS=(
        beams binarypath blackhole bouncyballs bubbles burn colorshift crumble
        decrypt errorcorrect expand fireworks highlight laseretch matrix
        middleout orbittingvolley overflow pour print rain randomsequence
        rings scattered slice slide smoke spotlights spray swarm sweep
        synthgrid thunderstorm unstable vhstape waves wipe
    )
    for eff in "${EFFECTS[@]}"; do
        echo "$eff"
        run_effect "$eff"
    done
elif [[ -n "$EFFECT" ]]; then
    run_effect "$EFFECT"
elif [[ `command -v tte` ]]; then
    run_effect smoke
elif [[ `command -v lolcat` ]]; then
    get_content | lolcat --seed=18 --spread=6
else
    get_content
fi
