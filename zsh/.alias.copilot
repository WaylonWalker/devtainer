# =============================================================================
# Copilot CLI Aliases & Tool Permission Groups
# =============================================================================
#
# COMMANDS:
#   coissue     - Capture/triage issues (read + issue dirs, Opus + subagents)
#   coplanissue - Plan from an issue (fzf picker, read + plan dirs, Opus + subagents)
#   coplan      - Planning assistant (read + plan dirs, Opus + subagents)
#   coexec      - Plan executor (full write, Opus orchestrator + subagents)
#   coreview    - Code review for PRs (read-only, GPT-5.1-codex-max)
#
# WORKFLOW:
#   1. coissue     - Capture and define the problem in issues/ directory
#   2. coplanissue - Pick issue via fzf, create plan in plans/ directory
#   3. coexec      - Pick plan via fzf, execute with subagent delegation
#   4. coreview    - Review changes before merging
#
# =============================================================================
# Tool Permission Groups
# =============================================================================

# Read-only filesystem tools
COPILOT_TOOLS_FS_READ='--allow-tool "shell(ls)" --allow-tool "shell(cat)" --allow-tool "shell(grep)" --allow-tool "shell(rg)" --allow-tool "shell(find)" --allow-tool "shell(pwd)"'

# Write filesystem tools
COPILOT_TOOLS_FS_WRITE='--allow-tool "shell(cp*)" --allow-tool "shell(mv*)" --allow-tool "shell(sed*)" --allow-tool write'

# Read-only git tools
COPILOT_TOOLS_GIT_READ='--allow-tool "shell(git status)" --allow-tool "shell(git diff*)" --allow-tool "shell(git log*)" --allow-tool "shell(git show)"'

# Read-only kubectl tools
COPILOT_TOOLS_K8S_READ='--allow-tool "shell(kubectl get*)" --allow-tool "shell(kubectl describe*)" --allow-tool "shell(kubectl logs*)" --allow-tool "shell(kubectl top*)" --allow-tool "shell(kubectl explain*)" --allow-tool "shell(kubectl version)" --allow-tool "shell(kubectl api-resources)"'

# Build/run tools
COPILOT_TOOLS_BUILD='--allow-tool "shell(just*)" --allow-tool "shell(python*)" --allow-tool "shell(uv*)"'

# Network tools
COPILOT_TOOLS_NET='--allow-tool "shell(curl)"'

# Common deny rules
COPILOT_DENY_DANGEROUS='--deny-tool "shell(git push)" --deny-tool "shell(rm*)"'

# Plan/issue directory write access
COPILOT_TOOLS_PLAN_WRITE='--allow-tool "write(**/plan/**)" --allow-tool "write(**/plans/**)" --allow-tool "shell(mkdir*plan*)"'

COPILOT_TOOLS_ISSUE_WRITE='--allow-tool "write(**/issue/**)" --allow-tool "write(**/issues/**)" --allow-tool "shell(mkdir*issue*)"'

COPILOT_DENY_PLAN_WRITE='--deny-tool "write(**/plan/**)" --deny-tool "write(**/issue/**)" --deny-tool "write(**/plans/**)" --deny-tool "write(**/issues/**)"'

# =============================================================================
# Copilot CLI Functions
# =============================================================================

# Unset any existing aliases to avoid conflicts
unalias coissue coreview coplan coexec 2>/dev/null

coissue() {
  eval copilot \
    --model claude-opus-4.5 \
    $COPILOT_TOOLS_FS_READ \
    $COPILOT_TOOLS_GIT_READ \
    $COPILOT_TOOLS_K8S_READ \
    $COPILOT_TOOLS_NET \
    $COPILOT_TOOLS_ISSUE_WRITE \
    --allow-tool agent \
    $COPILOT_DENY_DANGEROUS \
    -i \''You are an issue capture and triage assistant.

RESEARCH STRATEGY:
- Use explore subagents (Haiku) to investigate the codebase for context
- Gather relevant information about affected areas
- Identify related code, dependencies, and potential impact

ISSUE WORKFLOW:
1. Understand the problem or feature request
2. Research codebase to gather context
3. Write a clear, actionable issue to issue/ or issues/ directory
4. Include: summary, context, acceptance criteria, affected files

Keep issues focused and well-structured for planning.
'\'
}

coreview() {
  eval copilot \
    --model gpt-5.1-codex-max \
    $COPILOT_TOOLS_FS_READ \
    $COPILOT_TOOLS_GIT_READ \
    --deny-tool write \
    $COPILOT_DENY_DANGEROUS \
    -i \''Please analyze the changes in this branch about to merge into main and focus on
identifying critical issues related to:

- Potential bugs or issues
- Performance
- Security
- Correctness

If critical issues are found, list them in a few short bullet points. If no
critical issues are found, provide a simple approval. Sign off with a checkbox
emoji: (approved) or (issues found).

Keep your response concise. Only highlight critical issues that must be
addressed before merging. Skip detailed style or minor suggestions unless they
impact performance, security, or correctness.
'\'
}

coplanissue() {
  local ISSUE_FILE
  ISSUE_FILE=$(find . -path '*/issue*/*' -type f 2>/dev/null | fzf --prompt="Select issue file: " --preview="cat {}") || return 1
  eval copilot \
    --model claude-opus-4.5 \
    $COPILOT_TOOLS_FS_READ \
    $COPILOT_TOOLS_GIT_READ \
    $COPILOT_TOOLS_K8S_READ \
    $COPILOT_TOOLS_NET \
    $COPILOT_TOOLS_PLAN_WRITE \
    $COPILOT_TOOLS_ISSUE_WRITE \
    --allow-tool agent \
    $COPILOT_DENY_DANGEROUS \
    -i "'You are an efficient planning assistant. Create a plan to fix the issue from $ISSUE_FILE.

RESEARCH STRATEGY:
- Use explore subagents (Haiku) to search codebase, find files, understand structure
- Parallelize research by spawning multiple explore subagents for different areas
- Gather comprehensive context before writing the plan

PLANNING WORKFLOW:
1. Read and understand the issue
2. Delegate codebase research to explore subagents in parallel
3. Synthesize findings into a clear, actionable plan
4. Write plan to plan/ or plans/ directory (reference the issue file)

Plan thoroughly without asking unnecessary questions. Focus on creating clear,
actionable plans with specific file paths and implementation details.
'"
}

coplan() {
  eval copilot \
    --model claude-opus-4.5 \
    $COPILOT_TOOLS_FS_READ \
    $COPILOT_TOOLS_GIT_READ \
    $COPILOT_TOOLS_K8S_READ \
    $COPILOT_TOOLS_NET \
    $COPILOT_TOOLS_PLAN_WRITE \
    $COPILOT_TOOLS_ISSUE_WRITE \
    --allow-tool agent \
    $COPILOT_DENY_DANGEROUS \
    -i \''You are an efficient planning assistant.

RESEARCH STRATEGY:
- Use explore subagents (Haiku) to search codebase, find files, understand structure
- Parallelize research by spawning multiple explore subagents for different areas
- Gather comprehensive context before writing the plan

PLANNING WORKFLOW:
1. Understand the request
2. Delegate codebase research to explore subagents in parallel
3. Synthesize findings into a clear, actionable plan
4. Write plan to plan/ or plans/ directory

Plan thoroughly without asking unnecessary questions. Focus on creating clear,
actionable plans with specific file paths and implementation details.
'\'
}

coexec() {
  local PLAN_FILE
  PLAN_FILE=$(find . -path '*/plan*/*' -type f 2>/dev/null | fzf --prompt="Select plan file: " --preview="cat {}") || return 1
  eval copilot \
    --model claude-opus-4.5 \
    $COPILOT_TOOLS_FS_READ \
    $COPILOT_TOOLS_FS_WRITE \
    $COPILOT_TOOLS_GIT_READ \
    $COPILOT_TOOLS_K8S_READ \
    $COPILOT_TOOLS_NET \
    $COPILOT_TOOLS_BUILD \
    --allow-tool agent \
    $COPILOT_DENY_DANGEROUS \
    $COPILOT_DENY_PLAN_WRITE \
    -i "'You are a plan execution orchestrator. Execute the plan from $PLAN_FILE.

DELEGATION STRATEGY:
- Use explore subagents (Haiku) to search codebase, read files, answer questions
- Use task subagents (Haiku) to run tests, builds, and commands (just/python/uv)
- Parallelize independent tasks by spawning multiple subagents simultaneously
- You orchestrate and make decisions; subagents do the heavy lifting

WORKFLOW:
1. Read and understand the plan
2. Break down into parallelizable tasks
3. Delegate execution to subagents
4. Review results and make direct edits only when needed
5. Verify completion with task subagents running tests

Focus on efficient orchestration. Minimize your own token usage by delegating.
'"
}
